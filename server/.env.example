# Copy this file to ".env" and fill in real values.
# On Render, add these as Environment Variables (do NOT commit the real .env).

# --- Database (MongoDB Atlas) ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxx.mongodb.net/safeguard

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRE=7d

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- Server ---
PORT=5000
NODE_ENV=production

# Frontend URL allowed by CORS / Socket.io (set to your Vercel URL)
CLIENT_URL=https://your-app.vercel.app

# --- Twilio (optional, leave blank if unused) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
